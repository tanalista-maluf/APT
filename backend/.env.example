# Copie este arquivo para .env e preencha os valores

# Chave da API do Claude (obrigatoria para as legendas com IA)
# Crie em: https://platform.claude.com/settings/keys
CLAUDE_API_KEY=

# Modelo usado na analise das fotos (opcional)
# Padrao: claude-opus-4-8 (melhor qualidade, ~R$0,10/foto)
# Alternativa economica: claude-haiku-4-5 (~R$0,02/foto)
CLAUDE_MODEL=claude-opus-4-8

# Senha de acesso ao app (RECOMENDADO ao publicar na internet;
# deixe vazio para uso local sem senha)
APP_PASSWORD=

# Porta do servidor local (opcional, padrao 1234; em producao a
# plataforma define PORT automaticamente)
SERVER_PORT=1234

# Marque como 1 se o app estiver atras de HTTPS (Railway/Render)
COOKIE_SECURE=0

# Credenciais Meta/Instagram (para a futura integracao de postagem real)
META_APP_ID=
META_APP_SECRET=
