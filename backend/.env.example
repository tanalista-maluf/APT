# Copie este arquivo para .env e preencha os valores

# Chave da API do Claude (obrigatoria para as legendas com IA)
# Crie em: https://platform.claude.com/settings/keys
CLAUDE_API_KEY=

# Modelo usado na analise das fotos (opcional)
# Padrao: claude-opus-4-8 (melhor qualidade, ~R$0,10/foto)
# Alternativa economica: claude-haiku-4-5 (~R$0,02/foto)
CLAUDE_MODEL=claude-opus-4-8

# Senha de acesso ao app (RECOMENDADO ao publicar na internet;
# deixe vazio para uso local sem senha)
APP_PASSWORD=

# Porta do servidor local (opcional, padrao 1234; em producao a
# plataforma define PORT automaticamente)
SERVER_PORT=1234

# Marque como 1 se o app estiver atras de HTTPS (Railway/Render)
COOKIE_SECURE=0

# ---------------------------------------------------------------
# Publicacao automatica no Instagram
# ---------------------------------------------------------------

# Endereco publico HTTPS do app depois de publicado (ex: no Railway).
# O Instagram BUSCA a foto nesse endereco na hora de publicar, entao a
# publicacao real so funciona com isto definido e o app no ar.
# Ex: https://autopost-tabajara.up.railway.app
PUBLIC_BASE_URL=

# Liga/desliga o agendador que publica sozinho na hora marcada (padrao 1).
ENABLE_SCHEDULER=1

# De quanto em quanto tempo o agendador verifica posts vencidos (segundos).
SCHEDULER_INTERVAL=60

# Credenciais do app da Meta (opcionais aqui - servem para trocar um token
# curto por um de longa duracao automaticamente ao conectar).
# O ID da conta e o token do Instagram sao informados na tela de
# Configuracoes do app, nao aqui.
META_APP_ID=
META_APP_SECRET=
